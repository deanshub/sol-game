---
import Base from "../../../layouts/Base.astro";
import "../../../styles/shared-game.css";
import "../../../styles/sentence-complete.css";
---

<Base title="השלם את המשפט">
  <header class="game-header">
    <a href={import.meta.env.BASE_URL} class="back-link">חזרה</a>
    <h1 class="game-title">השלם את המשפט</h1>
    <div class="level-indicator" id="level-indicator"></div>
  </header>
  <div class="sentence-game-area" id="game-area">
    <div class="progress-text" id="progress"></div>
    <div class="sentence-text" id="sentence"></div>
    <div class="sentence-options" id="options"></div>
  </div>
  <div class="feedback" id="feedback"></div>
  <div id="game-data" data-base={import.meta.env.BASE_URL} hidden></div>
  <script>
    import "../../../games/sentence-complete/index";
  </script>
</Base>
