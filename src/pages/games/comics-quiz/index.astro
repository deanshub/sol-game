---
import Base from "../../../layouts/Base.astro";
import "../../../styles/shared-game.css";
import "../../../styles/comics-quiz.css";
---

<Base title="קומיקס וחידות">
  <header class="game-header">
    <a href={import.meta.env.BASE_URL} class="back-link">חזרה</a>
    <h1 class="game-title">קומיקס וחידות</h1>
    <div class="level-indicator" id="level-indicator"></div>
  </header>
  <div class="comics-game-area" id="game-area"></div>
  <div class="feedback" id="feedback"></div>
  <div id="game-data" data-base={import.meta.env.BASE_URL} hidden></div>
  <script>
    import "../../../games/comics-quiz/index";
  </script>
</Base>
