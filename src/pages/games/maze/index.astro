---
import Base from "../../../layouts/Base.astro";
import "../../../styles/shared-game.css";
import "../../../styles/maze.css";
---

<Base title="מבוך">
  <header class="game-header">
    <a href={import.meta.env.BASE_URL} class="back-link">חזרה</a>
    <h1 class="game-title">מבוך</h1>
    <div class="level-indicator" id="level-indicator"></div>
  </header>
  <div class="maze-game-area" id="game-area">
    <div class="progress-text" id="progress"></div>
    <div class="word-display" id="word-display"></div>
    <div class="maze-grid" id="maze-grid"></div>
    <div class="arrow-controls">
      <button class="arrow-btn" id="btn-up" type="button" aria-label="Up">▲</button>
      <button class="arrow-btn" id="btn-left" type="button" aria-label="Left">◀</button>
      <button class="arrow-btn" id="btn-down" type="button" aria-label="Down">▼</button>
      <button class="arrow-btn" id="btn-right" type="button" aria-label="Right">▶</button>
    </div>
  </div>
  <div class="feedback" id="feedback"></div>
  <div id="game-data" data-base={import.meta.env.BASE_URL} hidden></div>
  <script>
    import "../../../games/maze/index";
  </script>
</Base>
