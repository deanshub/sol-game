---
import Base from "../layouts/Base.astro";
const comicsUrl = `${import.meta.env.BASE_URL}games/comics-quiz/`;
---

<Base title="משחקי כיתה א1 של סול">
  <h1 class="page-title">משחקי כיתה א1 של סול</h1>
  <div class="game-grid">
    <a href={`${import.meta.env.BASE_URL}games/hebrew-match/`} class="game-card" data-game="hebrew-match">
      <div class="game-card-icon">אבג</div>
      <h2>התאמת אותיות</h2>
      <p>התאימו אותיות לתמונות</p>
    </a>
    <a href={`${import.meta.env.BASE_URL}games/picture-puzzle/`} class="game-card" data-game="picture-puzzle">
      <div class="game-card-icon">🧩</div>
      <h2>פאזל תמונות</h2>
      <p>הרכיבו את התמונה</p>
    </a>
    <a href={`${import.meta.env.BASE_URL}games/math-quiz/`} class="game-card" data-game="math-quiz">
      <div class="game-card-icon">➕</div>
      <h2>חשבון</h2>
      <p>חיבור וחיסור</p>
    </a>
    <div class="game-card countdown-card" id="timed-card" data-href={comicsUrl} data-game="comics-quiz">
      <div class="game-card-icon" id="timed-icon">🔒</div>
      <h2 id="timed-title">קומיקס וחידות</h2>
      <p id="timed-subtitle">קראו את הסיפור וענו</p>
      <div class="countdown-timer" id="countdown-timer"></div>
    </div>
  </div>
  <script>
    import { isCompleted } from "../shared/progress";

    document.querySelectorAll<HTMLElement>(".game-card[data-game]").forEach((card) => {
      const gameId = card.dataset.game!;
      if (isCompleted(gameId)) {
        card.classList.add("completed");
      }
    });

    const card = document.getElementById("timed-card")! as HTMLElement;
    const timerEl = document.getElementById("countdown-timer")!;
    const iconEl = document.getElementById("timed-icon")!;

    function getIsraelNow(): Date {
      return new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Jerusalem" }));
    }

    function getMsUntilNext18(): number {
      const now = new Date();
      const israel = getIsraelNow();
      const target = new Date(israel);
      target.setHours(18, 0, 0, 0);
      if (israel >= target) target.setDate(target.getDate() + 1);
      const diff = target.getTime() - israel.getTime();
      return diff;
    }

    const isBeta = new URLSearchParams(window.location.search).get("beta") === "true";

    function isUnlocked(): boolean {
      if (isBeta) return true;
      const israel = getIsraelNow();
      return israel.getHours() >= 18;
    }

    function pad(n: number): string {
      return String(n).padStart(2, "0");
    }

    function unlock() {
      card.classList.remove("countdown-card");
      iconEl.textContent = "💬";
      timerEl.style.display = "none";

      // Convert to a link
      const link = document.createElement("a");
      link.href = card.dataset.href!;
      link.className = card.className;
      link.dataset.game = card.dataset.game;
      link.innerHTML = card.innerHTML;
      card.replaceWith(link);

      // Check completed state
      if (isCompleted("comics-quiz")) {
        link.classList.add("completed");
      }
    }

    function tick() {
      if (isUnlocked()) {
        unlock();
        return;
      }

      const diff = Math.max(0, getMsUntilNext18());
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      timerEl.textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
    }

    tick();
    const interval = setInterval(() => {
      tick();
      if (isUnlocked()) clearInterval(interval);
    }, 1000);
  </script>
</Base>
