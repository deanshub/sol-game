---
import Base from "../layouts/Base.astro";
---

<Base title="משחקי כיתה א1 של סול">
  <h1 class="page-title">משחקי כיתה א1 של סול</h1>
  <div class="game-grid">
    <a href={`${import.meta.env.BASE_URL}games/hebrew-match/`} class="game-card">
      <div class="game-card-icon">אבג</div>
      <h2>התאמת אותיות</h2>
      <p>התאימו אותיות לתמונות</p>
    </a>
    <a href={`${import.meta.env.BASE_URL}games/picture-puzzle/`} class="game-card">
      <div class="game-card-icon">🧩</div>
      <h2>פאזל תמונות</h2>
      <p>הרכיבו את התמונה</p>
    </a>
    <div class="game-card countdown-card" id="countdown-card">
      <div class="game-card-icon">🔒</div>
      <h2>משחק חדש</h2>
      <div class="countdown-timer" id="countdown-timer"></div>
    </div>
  </div>
  <script>
    const timerEl = document.getElementById("countdown-timer")!;

    function getNextUnlock(): Date {
      const now = new Date();
      const israel = new Date(now.toLocaleString("en-US", { timeZone: "Asia/Jerusalem" }));
      const target = new Date(israel);
      target.setHours(18, 0, 0, 0);
      if (israel >= target) target.setDate(target.getDate() + 1);
      // Convert back: diff between israel-interpreted time and target
      const diff = target.getTime() - israel.getTime();
      return new Date(now.getTime() + diff);
    }

    function pad(n: number): string {
      return String(n).padStart(2, "0");
    }

    function tick() {
      const now = Date.now();
      const target = getNextUnlock().getTime();
      const diff = Math.max(0, target - now);

      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);

      timerEl.textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
    }

    tick();
    setInterval(tick, 1000);
  </script>
</Base>
