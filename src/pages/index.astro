---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base title="משחקי כיתה א1 של סול">
  <h1 class="page-title">משחקי כיתה א1 של סול</h1>
  <div class="game-grid" id="game-grid">
    <a href={`${base}games/hebrew-match/`} class="game-card" data-game="hebrew-match">
      <div class="game-card-icon">אבג</div>
      <h2>התאמת אותיות</h2>
      <p>התאימו אותיות לתמונות</p>
    </a>
    <a href={`${base}games/picture-puzzle/`} class="game-card" data-game="picture-puzzle">
      <div class="game-card-icon">🧩</div>
      <h2>פאזל תמונות</h2>
      <p>הרכיבו את התמונה</p>
    </a>
    <a href={`${base}games/math-quiz/`} class="game-card" data-game="math-quiz">
      <div class="game-card-icon">➕</div>
      <h2>חשבון</h2>
      <p>חיבור וחיסור</p>
    </a>
  </div>
  <script define:vars={{ base }}>
    window.__BASE_URL__ = base;
  </script>
  <script>
    import { isCompleted } from "../shared/progress";

    const base = (window as any).__BASE_URL__ as string;

    // Timed games in order — each unlocks at 18:00 Israel time on consecutive days
    const TIMED_GAMES = [
      { id: "comics-quiz", href: `${base}games/comics-quiz/`, icon: "💬", title: "קומיקס וחידות", subtitle: "קראו את הסיפור וענו" },
      { id: "english-quiz", href: `${base}games/english-quiz/`, icon: "🔤", title: "אנגלית", subtitle: "תרגלו מילים באנגלית", lockedSubtitle: "בקרוב..." },
      { id: "coming-soon", href: "#", icon: "🎮", title: "עוד משחק", subtitle: "בקרוב...", lockedSubtitle: "בקרוב..." },
    ];

    // Mark completed games
    document.querySelectorAll<HTMLElement>(".game-card[data-game]").forEach((card) => {
      if (isCompleted(card.dataset.game!)) card.classList.add("completed");
    });

    const grid = document.getElementById("game-grid")!;
    const isBeta = new URLSearchParams(window.location.search).get("beta") === "true";

    function getIsraelNow(): Date {
      return new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Jerusalem" }));
    }

    function isUnlockedNow(): boolean {
      if (isBeta) return true;
      return getIsraelNow().getHours() >= 18;
    }

    function getMsUntilNext18(): number {
      const israel = getIsraelNow();
      const target = new Date(israel);
      target.setHours(18, 0, 0, 0);
      if (israel >= target) target.setDate(target.getDate() + 1);
      return target.getTime() - israel.getTime();
    }

    function pad(n: number): string {
      return String(n).padStart(2, "0");
    }

    // Find the first timed game that hasn't been completed yet
    let currentTimedIndex = TIMED_GAMES.findIndex((g) => !isCompleted(g.id));
    if (currentTimedIndex === -1) currentTimedIndex = TIMED_GAMES.length; // all done

    // Add all completed timed games as regular cards
    for (let i = 0; i < currentTimedIndex; i++) {
      const g = TIMED_GAMES[i];
      const link = document.createElement("a");
      link.href = g.href;
      link.className = "game-card completed";
      link.dataset.game = g.id;
      link.innerHTML = `<div class="game-card-icon">${g.icon}</div><h2>${g.title}</h2><p>${g.subtitle}</p>`;
      grid.appendChild(link);
    }

    // If there's a next game to unlock, show it
    if (currentTimedIndex < TIMED_GAMES.length) {
      const current = TIMED_GAMES[currentTimedIndex];
      const next = currentTimedIndex + 1 < TIMED_GAMES.length ? TIMED_GAMES[currentTimedIndex + 1] : null;

      if (isUnlockedNow()) {
        // Show current as unlocked link
        const link = document.createElement("a");
        link.href = current.href;
        link.className = "game-card";
        link.dataset.game = current.id;
        link.innerHTML = `<div class="game-card-icon">${current.icon}</div><h2>${current.title}</h2><p>${current.subtitle}</p>`;
        grid.appendChild(link);

        // Show next as locked if exists
        if (next) {
          appendLockedCard(next);
        }
      } else {
        // Show current as locked countdown
        appendLockedCard(current);
      }
    }

    function appendLockedCard(game: typeof TIMED_GAMES[0]) {
      const card = document.createElement("div");
      card.className = "game-card countdown-card";
      card.id = "countdown-card";
      card.dataset.game = game.id;
      card.dataset.href = game.href;
      card.innerHTML =
        `<div class="game-card-icon" id="locked-icon">🔒</div>` +
        `<h2>${game.title}</h2>` +
        `<p>${game.lockedSubtitle || game.subtitle}</p>` +
        `<div class="countdown-timer" id="countdown-timer"></div>`;
      grid.appendChild(card);
      startCountdown(card, game);
    }

    function startCountdown(card: HTMLElement, game: typeof TIMED_GAMES[0]) {
      const timerEl = card.querySelector<HTMLElement>("#countdown-timer")!;
      const iconEl = card.querySelector<HTMLElement>("#locked-icon")!;

      function tick() {
        if (isUnlockedNow() && game.href !== "#") {
          // Unlock: convert to link
          card.classList.remove("countdown-card");
          iconEl.textContent = game.icon;
          timerEl.style.display = "none";

          const link = document.createElement("a");
          link.href = game.href;
          link.className = card.className;
          link.dataset.game = game.id;
          link.innerHTML = card.innerHTML;
          card.replaceWith(link);

          clearInterval(iv);

          // Show next locked card if exists
          const nextIdx = TIMED_GAMES.indexOf(game) + 1;
          if (nextIdx < TIMED_GAMES.length) {
            appendLockedCard(TIMED_GAMES[nextIdx]);
          }
          return;
        }

        const diff = Math.max(0, getMsUntilNext18());
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        timerEl.textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
      }

      tick();
      const iv = setInterval(tick, 1000);
    }
  </script>
</Base>
